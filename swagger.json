  "components": {
    "schemas": {
      "Product": {
        "type": "object",
        "properties": {
          "product_id": { "type": "string", "format": "uuid" },
          "labor_id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "listed_price": { "type": "number" },
          "sold_price": { "type": "number" },
          "status": { "type": "string", "enum": ["Available", "incart", "Sold"] },
          "quantity": { "type": "integer" },
          "sold": { "type": "integer" }
        }
      },
      "ProductInput": {
        "type": "object",
        "required": ["name", "labor_id"],
        "properties": {
          "product_id": { "type": "string", "format": "uuid" },
          "labor_id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "listed_price": { "type": "number" },
          "status": { "type": "string", "enum": ["Available", "incart", "Sold"], "default": "Available" },
          "quantity": { "type": "integer" }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "order_id": { "type": "string", "format": "uuid" },
          "buyer_id": { "type": "string" },
          "total_amount": { "type": "number" },
          "order_status": { "type": "string", "enum": ["processing", "shipped", "delivered"] },
          "order_type": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "OrderInput": {
        "type": "object",
        "required": ["buyer_id", "total_amount"],
        "properties": {
          "order_id": { "type": "string", "format": "uuid" },
          "buyer_id": { "type": "string" },
          "total_amount": { "type": "number" },
          "order_status": { "type": "string", "default": "processing" },
          "order_type": { "type": "string", "default": "customers" }
        }
      },
      "OrderItem": {
